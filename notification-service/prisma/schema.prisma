generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DispatchEventype {
  notification_send_alert @map("notification.send_alert")
  notification_send_sms   @map("notification.send_sms")
}

enum DispatchSeverity {
  medium
  high
  low
}

enum DispatchStatus {
  processing
  pending
  failed
  sent
}

model NotificationDispatch {
  id           String           @id @default(uuid())
  event_id     String           @unique
  job_id       String
  event_type   DispatchEventype
  user_id      String
  phone        String
  message      String
  severity     DispatchSeverity @default(medium)
  status       DispatchStatus   @default(pending)
  attempts     Int              @default(0)
  error_reason String?
  processed_at DateTime?
  created_at   DateTime         @default(now()) @db.Timestamptz()
}
