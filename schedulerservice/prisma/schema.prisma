generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid())
  username       String
  phone          String         @unique
  password       String
  email          String         @unique
  created_at     DateTime       @default(now()) @db.Timestamptz()
  scheduled_jobs ScheduledJob[]
  sessions       Session[]
}

model ScheduledJob {
  id                 String   @id @default(uuid())
  user_id            String
  payload            Json
  user               User     @relation(fields: [user_id], references: [id])
  run_at             DateTime @db.Timestamptz()
  recurrence_pattern String
  is_recurring       Boolean
  created_at         DateTime @default(now()) @db.Timestamptz()
  outboxes           Outbox[]

  @@index([user_id])
}

model Outbox {
  id           String       @id @default(uuid())
  schedule_id  String
  schedule_job ScheduledJob @relation(fields: [schedule_id], references: [id])
  event_id     String       @unique
  event        String
  payload      Json
  status       String       @default("pending")
  scheduled_at DateTime     @default(now()) @db.Timestamptz()
  error_reason String?
  processed_at DateTime?
  created_at   DateTime     @default(now()) @db.Timestamptz()

  @@index([schedule_id])
  @@index([status])
}

model Session {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([expires_at])
  @@index([user_id])
}
